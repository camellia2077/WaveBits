    <string name="brand_theme_mars_relic_title">火星遺物</string>
    <string name="brand_theme_mars_relic_description">深紅搭配羊皮紙色，呈現儀式檔案庫的氛圍。</string>
    <string name="brand_theme_mars_relic_accessibility">火星遺物主題，深紅配羊皮紙米色。</string>
    <string name="brand_theme_black_crimson_rite_title">黑紅儀式</string>
    <string name="brand_theme_black_crimson_rite_description">煤黑與儀式深紅，營造冷峻的機械神殿氣息。</string>
    <string name="brand_theme_black_crimson_rite_accessibility">黑紅儀式主題，近黑色搭配鮮明深紅。</string>
    <string name="brand_theme_scarlet_guard_title">猩紅衛隊</string>
    <string name="brand_theme_scarlet_guard_description">象牙白與封印深紅，呈現紀律分明的紋章感。</string>
    <string name="brand_theme_scarlet_guard_accessibility">猩紅衛隊主題，淺象牙白搭配深猩紅。</string>
    <string name="brand_theme_dynasty_revival_title">王朝再興</string>
    <string name="brand_theme_dynasty_revival_description">墓金屬黑與經典反應爐綠，帶出甦醒王朝核心的氣息。</string>
    <string name="brand_theme_dynasty_revival_accessibility">王朝再興主題，深墓金屬黑搭配明亮反應爐綠。</string>
    <string name="brand_theme_sepulcher_cyan_title">墓室青</string>
    <string name="brand_theme_sepulcher_cyan_description">冷冽墓室鋼與收斂的青綠色，呈現更沉靜的王室機械微光。</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">墓室青主題，冷色深鋼搭配低飽和青綠。</string>
    <string name="brand_theme_tomb_sigil_title">墓印</string>
    <string name="brand_theme_tomb_sigil_description">溫暖墓鐵與銳利復甦綠，形成儀式感王朝印記。</string>
    <string name="brand_theme_tomb_sigil_accessibility">墓印主題，深色墓鐵搭配鮮明復甦綠。</string>
    <string name="brand_theme_ancient_alloy_title">古老合金</string>
    <string name="brand_theme_ancient_alloy_description">風化金屬陰影與冷青綠，帶出墓冶爐般的光澤。</string>
    <string name="brand_theme_ancient_alloy_accessibility">古老合金主題，深青銅灰搭配明亮青綠。</string>
    <string name="brand_theme_immortal_rot_title">不朽腐朽</string>
    <string name="brand_theme_immortal_rot_description">蕨綠與檸晶黃構成潮濕、蔓生的 Dual-tone 色盤。</string>
    <string name="brand_theme_immortal_rot_accessibility">不朽腐朽主題，蕨綠搭配檸晶黃。</string>
    <string name="brand_theme_scarlet_carnage_title">猩紅屠戮</string>
    <string name="brand_theme_scarlet_carnage_description">深紅與黃銅鍛造出血色與戰爭金屬感的強烈 Dual-tone 色盤。</string>
    <string name="brand_theme_scarlet_carnage_accessibility">猩紅屠戮主題，深紅搭配深黃銅金。</string>
    <string name="brand_theme_exquisite_fall_title">華麗墮落</string>
    <string name="brand_theme_exquisite_fall_description">深暗紫與尖亮粉構成充滿虛榮與感官氣息的頹靡 Dual-tone 色盤。</string>
    <string name="brand_theme_exquisite_fall_accessibility">華麗墮落主題，深暗紫搭配尖亮粉與金色描邊。</string>
    <string name="brand_theme_labyrinth_of_mutability_title">變易迷宮</string>
    <string name="brand_theme_labyrinth_of_mutability_description">低飽和青藍與亮螢光紫構成變動不定、帶金色邊緣的 Dual-tone 迷宮。</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">變易迷宮主題，低飽和青藍搭配亮螢光紫與金色描邊。</string>
