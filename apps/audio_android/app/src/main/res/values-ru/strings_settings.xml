    <string name="brand_theme_custom_description">Ваши собственные двухцветные темы с примером текста Sacred Machine.</string>
    <!-- CONTEXT: Accessibility label read for the custom dual-tone theme preview swatch. -->
    <string name="brand_theme_custom_accessibility">Предпросмотр пользовательской двухцветной темы.</string>
