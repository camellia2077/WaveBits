    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Введите цвета в формате #RRGGBB. Оставьте поле контура пустым, чтобы использовать акцентный цвет.</string>
    <!-- CONTEXT: Button label that rolls a new random color combination for the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_randomize">Случайные цвета</string>
    <!-- CONTEXT: Helper hint next to the dice/randomize action in the custom dual-tone editor. -->
    <string name="config_custom_brand_theme_randomize_hint">Используйте кости, чтобы создать новое сочетание основного цвета, акцента и контура.</string>
