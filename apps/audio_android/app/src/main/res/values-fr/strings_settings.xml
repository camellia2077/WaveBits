    <!-- CONTEXT: Small action label for creating a new custom dual-tone preset. Keep it compact like a button or chip. -->
    <string name="config_custom_brand_theme_add">Ajouter</string>
    <!-- CONTEXT: Action label for opening the editor for an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_edit">Modifier les couleurs personnalisées</string>
    <!-- CONTEXT: Generic dialog title for the custom dual-tone color editor. -->
    <string name="config_custom_brand_theme_dialog_title">Couleurs Dual-tone personnalisées</string>
    <!-- CONTEXT: Dialog title when creating a brand-new custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_new">Nouveau Dual-tone personnalisé</string>
    <!-- CONTEXT: Dialog title when editing an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_edit">Modifier le Dual-tone personnalisé</string>
    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Saisissez des couleurs hexadécimales au format `#RRGGBB`. Laissez le contour vide pour réutiliser la couleur d’accent.</string>
    <!-- CONTEXT: Button label that rolls a new random color combination for the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_randomize">Aléatoiriser les couleurs</string>
    <!-- CONTEXT: Helper hint next to the dice/randomize action in the custom dual-tone editor. -->
    <string name="config_custom_brand_theme_randomize_hint">Utilisez les dés pour générer une nouvelle combinaison de couleurs.</string>
    <!-- CONTEXT: Form field label for the user-defined preset name. -->
    <string name="config_custom_brand_theme_name_label">Nom du préréglage</string>
    <!-- CONTEXT: Form field label for the main/background color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_background_label">Couleur principale</string>
    <!-- CONTEXT: Form field label for the accent/secondary color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_accent_label">Couleur d’accent</string>
    <!-- CONTEXT: Form field label for the outline/stroke color used by the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_outline_label">Couleur de contour</string>
    <!-- CONTEXT: Short marker shown beside the outline field to say the field may be left empty. Keep it very short. -->
    <string name="config_custom_brand_theme_outline_optional">Optionnel</string>
    <!-- CONTEXT: Confirm button label for saving the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_save">Enregistrer</string>
    <!-- CONTEXT: Destructive action label for deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete">Supprimer</string>
    <!-- CONTEXT: Confirmation dialog title shown before deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete_title">Supprimer le Dual-tone personnalisé</string>
    <!-- CONTEXT: Confirmation dialog message before deleting a custom dual-tone preset. %1$s is the preset name. -->
    <string name="config_custom_brand_theme_delete_message">Supprimer le préréglage %1$s ?</string>
    <!-- CONTEXT: Validation error shown when the preset name field is left empty. -->
    <string name="config_custom_brand_theme_invalid_name">Entrez un nom de préréglage.</string>
    <!-- CONTEXT: Validation error shown when a color field is not in #RRGGBB format. Keep the literal format unchanged. -->
    <string name="config_custom_brand_theme_invalid_hex">Utilisez `#RRGGBB`.</string>
