    <string name="brand_theme_mars_relic_title">Relique martienne</string>
    <string name="brand_theme_mars_relic_description">Rouge profond associé au parchemin pour une allure d’archive cérémonielle.</string>
    <string name="brand_theme_mars_relic_accessibility">Thème Relique martienne, rouge profond avec beige parchemin.</string>
    <string name="brand_theme_black_crimson_rite_title">Rite cramoisi noir</string>
    <string name="brand_theme_black_crimson_rite_description">Noir suie et cramoisi rituel pour une atmosphère sévère de sanctuaire mécanique.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Thème Rite cramoisi noir, presque noir avec rouge cramoisi vif.</string>
    <string name="brand_theme_scarlet_guard_title">Garde écarlate</string>
    <string name="brand_theme_scarlet_guard_description">Blanc ivoire et cramoisi scellé pour une tonalité héraldique disciplinée.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Thème Garde écarlate, ivoire clair avec rouge écarlate foncé.</string>
    <string name="brand_theme_dynasty_revival_title">Renaissance dynastique</string>
    <string name="brand_theme_dynasty_revival_description">Noir métal funéraire et vert réacteur classique pour un noyau dynastique réveillé.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Thème Renaissance dynastique, noir métal funéraire profond avec vert réacteur lumineux.</string>
    <string name="brand_theme_sepulcher_cyan_title">Cyan sépulcral</string>
    <string name="brand_theme_sepulcher_cyan_description">Acier sépulcral froid et cyan vert discret pour une lueur royale mécanique plus calme.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Thème Cyan sépulcral, acier sombre et froid avec cyan vert atténué.</string>
    <string name="brand_theme_tomb_sigil_title">Sceau funéraire</string>
    <string name="brand_theme_tomb_sigil_description">Fer de crypte chaleureux et vert de réveil vif pour un signe dynastique cérémoniel.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Thème Sceau funéraire, fer de crypte sombre avec vert de réveil vif.</string>
    <string name="brand_theme_ancient_alloy_title">Alliage ancien</string>
    <string name="brand_theme_ancient_alloy_description">Ombres de métal vieilli et turquoise froide pour la lueur d’une forge funéraire.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Thème Alliage ancien, gris bronze sombre avec turquoise vive.</string>
    <string name="brand_theme_immortal_rot_title">La Pourriture immortelle</string>
    <string name="brand_theme_immortal_rot_description">Vert fougère et jaune citrine créent une palette Dual-tone humide et envahie.</string>
    <string name="brand_theme_immortal_rot_accessibility">Thème La Pourriture immortelle, vert fougère avec jaune citrine.</string>
    <string name="brand_theme_scarlet_carnage_title">Le Carnage écarlate</string>
    <string name="brand_theme_scarlet_carnage_description">Rouge sombre et laiton forgent une palette Dual-tone brutale de sang et de métal de guerre.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Thème Le Carnage écarlate, rouge sombre avec laiton doré foncé.</string>
    <string name="brand_theme_exquisite_fall_title">La Chute exquise</string>
    <string name="brand_theme_exquisite_fall_description">Violet très sombre et rose criard créent une palette Dual-tone décadente de vanité et de sensation.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Thème Chute exquise, violet très sombre avec rose criard et contour doré.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Le Labyrinthe de la mutabilité</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Bleu cyan peu saturé et violet fluorescent vif forment un labyrinthe Dual-tone mouvant aux bords dorés.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Thème Le Labyrinthe de la mutabilité, bleu cyan peu saturé avec violet fluorescent vif et contour doré.</string>
