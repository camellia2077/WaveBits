    <string name="palette_mars_relic_title">Reliquia di Marte</string>
    <string name="brand_theme_mars_relic_title">Reliquia di Marte</string>
    <string name="brand_theme_mars_relic_description">Rosso intenso abbinato alla pergamena per un’estetica da archivio cerimoniale.</string>
    <string name="brand_theme_mars_relic_accessibility">Tema Reliquia di Marte, rosso intenso con beige pergamena.</string>
    <string name="brand_theme_black_crimson_rite_title">Rito cremisi nero</string>
    <string name="brand_theme_black_crimson_rite_description">Nero fuliggine e cremisi rituale per un’atmosfera severa da santuario meccanico.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Tema Rito cremisi nero, quasi nero con rosso cremisi vivido.</string>
    <string name="brand_theme_scarlet_guard_title">Guardia scarlatta</string>
    <string name="brand_theme_scarlet_guard_description">Bianco avorio e cremisi sigillato per un tono araldico disciplinato.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Tema Guardia scarlatta, avorio chiaro con rosso scarlatto scuro.</string>
    <string name="brand_theme_dynasty_revival_title">Rinascita della Dinastia</string>
    <string name="brand_theme_dynasty_revival_description">Nero metallo tombale e verde reattore classico per un nucleo dinastico risvegliato.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Tema Rinascita della Dinastia, nero metallo tombale profondo con verde reattore brillante.</string>
    <string name="brand_theme_sepulcher_cyan_title">Ciano sepolcrale</string>
    <string name="brand_theme_sepulcher_cyan_description">Acciaio sepolcrale freddo e ciano verde contenuto per un bagliore meccanico regale più discreto.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Tema Ciano sepolcrale, acciaio freddo scuro con ciano verde attenuato.</string>
    <string name="brand_theme_tomb_sigil_title">Sigillo tombale</string>
    <string name="brand_theme_tomb_sigil_description">Ferro di cripta caldo e verde del risveglio vivido per un marchio dinastico cerimoniale.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tema Sigillo tombale, ferro di cripta scuro con verde del risveglio vivido.</string>
    <string name="brand_theme_ancient_alloy_title">Lega antica</string>
    <string name="brand_theme_ancient_alloy_description">Ombre di metallo consumato e turchese freddo per un bagliore da forgia sepolcrale.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Tema Lega antica, grigio bronzo scuro con turchese brillante.</string>
    <string name="brand_theme_immortal_rot_title">La Marcescenza Immortale</string>
    <string name="brand_theme_immortal_rot_description">Verde felce e giallo citrino creano una palette Dual-tone umida e invasa.</string>
    <string name="brand_theme_immortal_rot_accessibility">Tema La Marcescenza Immortale, verde felce con giallo citrino.</string>
    <string name="brand_theme_scarlet_carnage_title">La Carneficina Scarlatta</string>
    <string name="brand_theme_scarlet_carnage_description">Rosso scuro e ottone forgiano una brutale palette Dual-tone di sangue e metallo di guerra.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Tema La Carneficina Scarlatta, rosso scuro con ottone dorato scuro.</string>
    <string name="brand_theme_exquisite_fall_title">La Caduta Squisita</string>
    <string name="brand_theme_exquisite_fall_description">Viola molto scuro e rosa stridente creano una palette Dual-tone decadente di vanità e sensazione.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Tema Caduta Squisita, viola molto scuro con rosa stridente e contorno dorato.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Il Labirinto della Mutabilità</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Blu ciano a bassa saturazione e viola fluorescente brillante formano un labirinto Dual-tone mutevole con bordo dorato.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Tema Il Labirinto della Mutabilità, blu ciano a bassa saturazione con viola fluorescente brillante e contorno dorato.</string>
    <!-- CONTEXT: Display name for the built-in "custom" dual-tone theme option. This is the title shown in settings, not a button. -->
    <string name="brand_theme_custom_title">Dual-tone personalizzato</string>
    <!-- CONTEXT: Short description under the custom dual-tone theme option. Explain that the user chooses colors but sample text still follows the Sacred Machine flavor. -->
    <string name="brand_theme_custom_description">I tuoi colori Dual-tone con il testo di esempio de La Macchina Sacra.</string>
    <!-- CONTEXT: Accessibility label read for the custom dual-tone theme preview swatch. -->
    <string name="brand_theme_custom_accessibility">Anteprima del tema Dual-tone personalizzato.</string>
    <!-- CONTEXT: Small action label for creating a new custom dual-tone preset. Keep it compact like a button or chip. -->
    <string name="config_custom_brand_theme_add">Aggiungi</string>
    <!-- CONTEXT: Action label for opening the editor for an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_edit">Modifica colori personalizzati</string>
    <!-- CONTEXT: Generic dialog title for the custom dual-tone color editor. -->
    <string name="config_custom_brand_theme_dialog_title">Colori Dual-tone personalizzati</string>
    <!-- CONTEXT: Dialog title when creating a brand-new custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_new">Nuovo Dual-tone personalizzato</string>
    <!-- CONTEXT: Dialog title when editing an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_edit">Modifica Dual-tone personalizzato</string>
    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Inserisci colori hex nel formato #RRGGBB. Lascia il contorno vuoto per riutilizzare il colore d\'accento.</string>
    <!-- CONTEXT: Button label that rolls a new random color combination for the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_randomize">Casualizza colori</string>
    <!-- CONTEXT: Helper hint next to the dice/randomize action in the custom dual-tone editor. -->
    <string name="config_custom_brand_theme_randomize_hint">Usa i dadi per generare una nuova combinazione di colori.</string>
    <!-- CONTEXT: Form field label for the user-defined preset name. -->
    <string name="config_custom_brand_theme_name_label">Nome del preset</string>
    <!-- CONTEXT: Form field label for the main/background color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_background_label">Colore principale</string>
    <!-- CONTEXT: Form field label for the accent/secondary color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_accent_label">Colore d\'accento</string>
    <!-- CONTEXT: Form field label for the outline/stroke color used by the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_outline_label">Colore contorno</string>
    <!-- CONTEXT: Short marker shown beside the outline field to say the field may be left empty. Keep it very short. -->
    <string name="config_custom_brand_theme_outline_optional">Opzionale</string>
    <!-- CONTEXT: Confirm button label for saving the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_save">Salva</string>
    <!-- CONTEXT: Destructive action label for deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete">Elimina</string>
    <!-- CONTEXT: Confirmation dialog title shown before deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete_title">Elimina Dual-tone personalizzato</string>
    <!-- CONTEXT: Confirmation dialog message before deleting a custom dual-tone preset. %1$s is the preset name. -->
    <string name="config_custom_brand_theme_delete_message">Eliminare il preset %1$s?</string>
    <!-- CONTEXT: Validation error shown when the preset name field is left empty. -->
    <string name="config_custom_brand_theme_invalid_name">Inserisci un nome per il preset.</string>
    <!-- CONTEXT: Validation error shown when a color field is not in #RRGGBB format. Keep the literal format unchanged. -->
    <string name="config_custom_brand_theme_invalid_hex">Usa #RRGGBB.</string>
