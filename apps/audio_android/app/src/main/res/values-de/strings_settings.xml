    <string name="brand_theme_mars_relic_description">Tiefrot mit Pergament für den Look eines zeremoniellen Archivs.</string>
    <string name="brand_theme_mars_relic_accessibility">Mars-Relikt-Design, tiefes Rot mit pergamentbeigem Ton.</string>
    <string name="brand_theme_black_crimson_rite_title">Schwarzroter Ritus</string>
    <string name="brand_theme_black_crimson_rite_description">Rußschwarz und Ritualkarmesin für die strenge Stimmung eines Maschinenschreins.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Schwarzroter-Ritus-Design, fast schwarz mit leuchtendem Karmesinrot.</string>
    <string name="brand_theme_scarlet_guard_title">Scharlachwache</string>
    <string name="brand_theme_scarlet_guard_description">Elfenbeinweiß und versiegeltes Karmesin für einen disziplinierten heraldischen Ton.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Scharlachwache-Design, helles Elfenbein mit dunklem Scharlachrot.</string>
    <string name="brand_theme_dynasty_revival_title">Wiederkehr der Dynastie</string>
    <string name="brand_theme_dynasty_revival_description">Grabmetallschwarz mit klassischem Reaktorgrün für einen erwachten Dynastiekern.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Wiederkehr-der-Dynastie-Design, tiefes Grabmetallschwarz mit hellem Reaktorgrün.</string>
    <string name="brand_theme_sepulcher_cyan_title">Grabkammer-Cyan</string>
    <string name="brand_theme_sepulcher_cyan_description">Kalter Grabkammerstahl mit zurückhaltendem Cyan-Grün für ein ruhigeres königliches Maschinenglühen.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Grabkammer-Cyan-Design, kalter dunkler Stahl mit gedämpftem Cyan-Grün.</string>
    <string name="brand_theme_tomb_sigil_title">Grabsiegel</string>
    <string name="brand_theme_tomb_sigil_description">Warmes Kryptaeisen und scharfes Erweckungsgrün für ein zeremonielles Dynastiezeichen.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Grabsiegel-Design, dunkles Kryptaeisen mit leuchtendem Erweckungsgrün.</string>
    <string name="brand_theme_ancient_alloy_title">Uralte Legierung</string>
    <string name="brand_theme_ancient_alloy_description">Verwitterte Metallschatten und kaltes Türkis für das Glühen einer Grabesschmiede.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Uralte-Legierung-Design, dunkles Bronze-Grau mit hellem Türkis.</string>
    <string name="brand_theme_immortal_rot_title">Die unsterbliche Fäulnis</string>
    <string name="brand_theme_immortal_rot_description">Farngrün und Citringelb bilden eine feuchte, überwucherte Dual-tone-Palette.</string>
    <string name="brand_theme_immortal_rot_accessibility">Die-unsterbliche-Fäulnis-Design, Farngrün mit Citringelb.</string>
    <string name="brand_theme_scarlet_carnage_title">Das scharlachrote Gemetzel</string>
    <string name="brand_theme_scarlet_carnage_description">Dunkelrot und Messing formen eine brutale Dual-tone-Palette aus Blut und Kriegsmetall.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Das-scharlachrote-Gemetzel-Design, Dunkelrot mit messingfarbenem Dunkelgold.</string>
    <string name="brand_theme_exquisite_fall_title">Erlesener Fall</string>
    <string name="brand_theme_exquisite_fall_description">Tiefdunkles Lila und kreischendes Pink schaffen eine dekadente Dual-tone-Palette aus Eitelkeit und Reiz.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Erlesener-Fall-Design, tiefdunkles Lila mit kreischendem Pink und goldener Kontur.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Das Labyrinth der Wandelbarkeit</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Cyanblau mit niedriger Sättigung und helles Fluor-Lila bilden ein wechselndes Dual-tone-Labyrinth mit goldener Kante.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Labyrinth-der-Wandelbarkeit-Design, cyanblau mit niedriger Sättigung, helles Fluor-Lila und goldene Kontur.</string>
    <!-- CONTEXT: Display name for the built-in "custom" dual-tone theme option. This is the title shown in settings, not a button. -->
    <string name="brand_theme_custom_title">Benutzerdefiniertes Dual-Tone</string>
    <!-- CONTEXT: Short description under the custom dual-tone theme option. Explain that the user chooses colors but sample text still follows the Sacred Machine flavor. -->
    <string name="brand_theme_custom_description">Eigene Dual-Tone-Farben mit Sacred-Machine-Beispieltext.</string>
    <!-- CONTEXT: Accessibility label read for the custom dual-tone theme preview swatch. -->
    <string name="brand_theme_custom_accessibility">Vorschau des benutzerdefinierten Dual-Tone-Themes.</string>
    <!-- CONTEXT: Small action label for creating a new custom dual-tone preset. Keep it compact like a button or chip. -->
    <string name="config_custom_brand_theme_add">Hinzufügen</string>
    <!-- CONTEXT: Action label for opening the editor for an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_edit">Eigene Farben bearbeiten</string>
    <!-- CONTEXT: Generic dialog title for the custom dual-tone color editor. -->
    <string name="config_custom_brand_theme_dialog_title">Benutzerdefinierte Dual-Tone-Farben</string>
    <!-- CONTEXT: Dialog title when creating a brand-new custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_new">Neues benutzerdefiniertes Dual-Tone</string>
    <!-- CONTEXT: Dialog title when editing an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_edit">Benutzerdefiniertes Dual-Tone bearbeiten</string>
    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Hex-Farben im Format #RRGGBB eingeben. Umrandung leer lassen, um die Akzentfarbe zu verwenden.</string>
    <!-- CONTEXT: Button label that rolls a new random color combination for the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_randomize">Farben zufällig wählen</string>
    <!-- CONTEXT: Helper hint next to the dice/randomize action in the custom dual-tone editor. -->
    <string name="config_custom_brand_theme_randomize_hint">Würfel verwenden, um eine neue Kombination aus Primär-, Akzent- und Umrandungsfarbe zu generieren.</string>
    <!-- CONTEXT: Form field label for the user-defined preset name. -->
    <string name="config_custom_brand_theme_name_label">Name der Voreinstellung</string>
    <!-- CONTEXT: Form field label for the main/background color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_background_label">Primärfarbe</string>
    <!-- CONTEXT: Form field label for the accent/secondary color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_accent_label">Akzentfarbe</string>
    <!-- CONTEXT: Form field label for the outline/stroke color used by the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_outline_label">Umrandungsfarbe</string>
    <!-- CONTEXT: Short marker shown beside the outline field to say the field may be left empty. Keep it very short. -->
    <string name="config_custom_brand_theme_outline_optional">Optional</string>
    <!-- CONTEXT: Confirm button label for saving the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_save">Speichern</string>
    <!-- CONTEXT: Destructive action label for deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete">Löschen</string>
    <!-- CONTEXT: Confirmation dialog title shown before deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete_title">Benutzerdefiniertes Dual-Tone löschen</string>
    <!-- CONTEXT: Confirmation dialog message before deleting a custom dual-tone preset. %1$s is the preset name. -->
    <string name="config_custom_brand_theme_delete_message">Voreinstellung %1$s löschen?</string>
    <!-- CONTEXT: Validation error shown when the preset name field is left empty. -->
    <string name="config_custom_brand_theme_invalid_name">Namen für Voreinstellung eingeben.</string>
    <!-- CONTEXT: Validation error shown when a color field is not in #RRGGBB format. Keep the literal format unchanged. -->
    <string name="config_custom_brand_theme_invalid_hex">#RRGGBB verwenden.</string>
