    <string name="config_custom_brand_theme_dialog_title_new">New custom dual-tone</string>
    <!-- CONTEXT: Dialog title when editing an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_edit">Edit custom dual-tone</string>
    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Enter hex colors in #RRGGBB format. Leave outline empty to reuse the accent color.</string>
