    <string name="brand_theme_mars_relic_title">Mars Relic</string>
    <string name="brand_theme_mars_relic_description">Deep red paired with parchment for a ceremonial archive look.</string>
    <string name="brand_theme_mars_relic_accessibility">Mars Relic theme, deep red with parchment beige.</string>
    <string name="brand_theme_black_crimson_rite_title">Black Crimson Rite</string>
    <string name="brand_theme_black_crimson_rite_description">Soot black and ritual crimson for a severe machine shrine mood.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Black Crimson Rite theme, near-black with vivid crimson red.</string>
    <string name="brand_theme_scarlet_guard_title">Scarlet Guard</string>
    <string name="brand_theme_scarlet_guard_description">Ivory white and sealed crimson for a disciplined heraldic tone.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Scarlet Guard theme, light ivory with dark scarlet red.</string>
    <string name="brand_theme_dynasty_revival_title">Dynasty Revival</string>
    <string name="brand_theme_dynasty_revival_description">Tomb-metal black with classic reactor green for a reawakened dynasty core.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Dynasty Revival theme, deep tomb-metal black with bright reactor green.</string>
    <string name="brand_theme_sepulcher_cyan_title">Sepulcher Cyan</string>
    <string name="brand_theme_sepulcher_cyan_description">Cold sepulcher steel with restrained cyan-green for a quieter royal machine glow.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Sepulcher Cyan theme, cold dark steel with muted cyan-green.</string>
    <string name="brand_theme_tomb_sigil_title">Tomb Sigil</string>
    <string name="brand_theme_tomb_sigil_description">Warm crypt iron and sharp revival green for a ceremonial dynasty mark.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tomb Sigil theme, dark crypt iron with vivid revival green.</string>
    <string name="brand_theme_ancient_alloy_title">Ancient Alloy</string>
    <string name="brand_theme_ancient_alloy_description">Weathered metal shadows and cold turquoise for a tomb-forge glow.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Ancient Alloy theme, dark bronze gray with bright turquoise.</string>
    <string name="brand_theme_immortal_rot_title">The Immortal Rot</string>
    <string name="brand_theme_immortal_rot_description">Fern green and citrine yellow create a damp, overgrown dual-tone palette.</string>
    <string name="brand_theme_immortal_rot_accessibility">The Immortal Rot theme, fern green with citrine yellow.</string>
    <string name="brand_theme_scarlet_carnage_title">The Scarlet Carnage</string>
    <string name="brand_theme_scarlet_carnage_description">Dark red and brass forge a brutal dual-tone palette of blood and war metal.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">The Scarlet Carnage theme, dark red with dark goldenrod brass.</string>
    <string name="brand_theme_exquisite_fall_title">The Exquisite Fall</string>
    <string name="brand_theme_exquisite_fall_description">Deep dark purple and screamer pink create a decadent dual-tone palette of vanity and sensation.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Exquisite Fall theme, deep dark purple with screamer pink and gold outline.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">The Labyrinth of Mutability</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Low-saturation cyan blue and bright fluorescent purple form a shifting dual-tone maze with a golden edge.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">The Labyrinth of Mutability theme, low-saturation cyan blue with bright fluorescent purple and gold outline.</string>
