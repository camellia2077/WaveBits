    <string name="audio_transport_flash_example">Los guardianes de lámpara despliegan la vieja carta celeste</string>
    <string name="audio_transport_pro_hint">pro solo admite entrada ASCII.</string>
    <string name="audio_transport_pro_example">BELLS MARK THE FIRST WATCH</string>
