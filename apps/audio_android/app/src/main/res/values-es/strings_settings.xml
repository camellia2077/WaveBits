    <string name="palette_mars_relic_title">Reliquia de Marte</string>
    <string name="brand_theme_mars_relic_title">Reliquia de Marte</string>
    <string name="brand_theme_mars_relic_description">Rojo profundo con pergamino para una estética de archivo ceremonial.</string>
    <string name="brand_theme_mars_relic_accessibility">Tema Reliquia de Marte, rojo profundo con beige pergamino.</string>
    <string name="brand_theme_black_crimson_rite_title">Rito carmesí negro</string>
    <string name="brand_theme_black_crimson_rite_description">Negro hollín y carmesí ritual para una atmósfera severa de santuario mecánico.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Tema Rito carmesí negro, casi negro con rojo carmesí intenso.</string>
    <string name="brand_theme_scarlet_guard_title">Guardia escarlata</string>
    <string name="brand_theme_scarlet_guard_description">Blanco marfil y carmesí sellado para un tono heráldico disciplinado.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Tema Guardia escarlata, marfil claro con rojo escarlata oscuro.</string>
    <string name="brand_theme_dynasty_revival_title">Renacer de la Dinastía</string>
    <string name="brand_theme_dynasty_revival_description">Negro de metal funerario con verde reactor clásico para un núcleo dinástico reanimado.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Tema Renacer de la Dinastía, negro metal funerario profundo con verde reactor brillante.</string>
    <string name="brand_theme_sepulcher_cyan_title">Cian sepulcral</string>
    <string name="brand_theme_sepulcher_cyan_description">Acero sepulcral frío con cian verdoso contenido para un resplandor regio y mecánico más sereno.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Tema Cian sepulcral, acero frío y oscuro con cian verdoso apagado.</string>
    <string name="brand_theme_tomb_sigil_title">Sigilo funerario</string>
    <string name="brand_theme_tomb_sigil_description">Hierro cálido de cripta y verde de resurgimiento intenso para un emblema ceremonial dinástico.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tema Sigilo funerario, hierro oscuro de cripta con verde de resurgimiento intenso.</string>
    <string name="brand_theme_ancient_alloy_title">Aleación antigua</string>
    <string name="brand_theme_ancient_alloy_description">Sombras de metal envejecido y turquesa fría para el brillo de una forja sepulcral.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Tema Aleación antigua, gris bronce oscuro con turquesa brillante.</string>
    <string name="brand_theme_immortal_rot_title">La Putrefacción Inmortal</string>
    <string name="brand_theme_immortal_rot_description">Verde helecho y amarillo citrino crean una paleta Dual-tone húmeda y cubierta de maleza.</string>
    <string name="brand_theme_immortal_rot_accessibility">Tema La Putrefacción Inmortal, verde helecho con amarillo citrino.</string>
    <string name="brand_theme_scarlet_carnage_title">La Carnicería Escarlata</string>
    <string name="brand_theme_scarlet_carnage_description">Rojo oscuro y latón forjan una brutal paleta Dual-tone de sangre y metal de guerra.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Tema La Carnicería Escarlata, rojo oscuro con latón dorado oscuro.</string>
    <string name="brand_theme_exquisite_fall_title">La Caída Exquisita</string>
    <string name="brand_theme_exquisite_fall_description">Púrpura muy oscuro y rosa estridente crean una paleta Dual-tone decadente de vanidad y sensación.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Tema Caída Exquisita, púrpura muy oscuro con rosa estridente y contorno dorado.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">El Laberinto de la Mutabilidad</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Azul cian de baja saturación y púrpura fluorescente brillante forman un laberinto Dual-tone cambiante con borde dorado.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Tema El Laberinto de la Mutabilidad, azul cian de baja saturación con púrpura fluorescente brillante y contorno dorado.</string>
    <!-- CONTEXT: Display name for the built-in "custom" dual-tone theme option. This is the title shown in settings, not a button. -->
    <string name="brand_theme_custom_title">Bitono personalizado</string>
    <!-- CONTEXT: Short description under the custom dual-tone theme option. Explain that the user chooses colors but sample text still follows the Sacred Machine flavor. -->
    <string name="brand_theme_custom_description">Tus propios colores bitono con el texto de ejemplo de La Máquina Sagrada.</string>
    <!-- CONTEXT: Accessibility label read for the custom dual-tone theme preview swatch. -->
    <string name="brand_theme_custom_accessibility">Vista previa del tema bitono personalizado.</string>
    <!-- CONTEXT: Small action label for creating a new custom dual-tone preset. Keep it compact like a button or chip. -->
    <string name="config_custom_brand_theme_add">Añadir</string>
    <!-- CONTEXT: Action label for opening the editor for an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_edit">Editar colores personalizados</string>
    <!-- CONTEXT: Generic dialog title for the custom dual-tone color editor. -->
    <string name="config_custom_brand_theme_dialog_title">Colores bitono personalizados</string>
    <!-- CONTEXT: Dialog title when creating a brand-new custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_new">Nuevo bitono personalizado</string>
    <!-- CONTEXT: Dialog title when editing an existing custom dual-tone preset. -->
    <string name="config_custom_brand_theme_dialog_title_edit">Editar bitono personalizado</string>
    <!-- CONTEXT: Helper text inside the custom dual-tone editor. It explains the required hex format and that outline may be left empty. -->
    <string name="config_custom_brand_theme_dialog_description">Introduce colores hex en formato #RRGGBB. Deja el contorno vacío para reutilizar el color de acento.</string>
    <!-- CONTEXT: Button label that rolls a new random color combination for the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_randomize">Aleatorizar colores</string>
    <!-- CONTEXT: Helper hint next to the dice/randomize action in the custom dual-tone editor. -->
    <string name="config_custom_brand_theme_randomize_hint">Usa los dados para generar una nueva combinación de colores.</string>
    <!-- CONTEXT: Form field label for the user-defined preset name. -->
    <string name="config_custom_brand_theme_name_label">Nombre del ajuste</string>
    <!-- CONTEXT: Form field label for the main/background color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_background_label">Color principal</string>
    <!-- CONTEXT: Form field label for the accent/secondary color of the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_accent_label">Color de acento</string>
    <!-- CONTEXT: Form field label for the outline/stroke color used by the custom dual-tone theme. -->
    <string name="config_custom_brand_theme_outline_label">Color de contorno</string>
    <!-- CONTEXT: Short marker shown beside the outline field to say the field may be left empty. Keep it very short. -->
    <string name="config_custom_brand_theme_outline_optional">Opcional</string>
    <!-- CONTEXT: Confirm button label for saving the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_save">Guardar</string>
    <!-- CONTEXT: Destructive action label for deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete">Eliminar</string>
    <!-- CONTEXT: Confirmation dialog title shown before deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete_title">Eliminar bitono personalizado</string>
    <!-- CONTEXT: Confirmation dialog message before deleting a custom dual-tone preset. %1$s is the preset name. -->
    <string name="config_custom_brand_theme_delete_message">¿Eliminar el ajuste %1$s?</string>
    <!-- CONTEXT: Validation error shown when the preset name field is left empty. -->
    <string name="config_custom_brand_theme_invalid_name">Introduce un nombre.</string>
    <!-- CONTEXT: Validation error shown when a color field is not in #RRGGBB format. Keep the literal format unchanged. -->
    <string name="config_custom_brand_theme_invalid_hex">Usa #RRGGBB.</string>
