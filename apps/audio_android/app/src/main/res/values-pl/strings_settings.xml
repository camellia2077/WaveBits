    <string name="config_custom_brand_theme_outline_label">Kolor obramowania</string>
    <!-- CONTEXT: Short marker shown beside the outline field to say the field may be left empty. Keep it very short. -->
    <string name="config_custom_brand_theme_outline_optional">Opcjonalnie</string>
    <!-- CONTEXT: Confirm button label for saving the custom dual-tone preset. -->
    <string name="config_custom_brand_theme_save">Zapisz</string>
    <!-- CONTEXT: Destructive action label for deleting a custom dual-tone preset. -->
    <string name="config_custom_brand_theme_delete">Usuń</string>
