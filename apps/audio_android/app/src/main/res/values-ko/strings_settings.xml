    <string name="brand_theme_black_crimson_rite_accessibility">블랙 크림슨 라이트 테마, 검은색에 가까운 색과 선명한 진홍색.</string>
    <string name="brand_theme_scarlet_guard_title">스칼렛 가드</string>
    <string name="brand_theme_scarlet_guard_description">절제된 문장학적 톤을 위한 아이보리 화이트와 봉인된 진홍색.</string>
    <string name="brand_theme_scarlet_guard_accessibility">스칼렛 가드 테마, 밝은 아이보리와 어두운 스칼렛 레드.</string>
    <string name="brand_theme_dynasty_revival_title">다이너스티 리바이벌</string>
    <string name="brand_theme_dynasty_revival_description">다시 깨어난 왕조의 핵심을 표현한 툼 메탈 블랙과 클래식 리액터 그린.</string>
    <string name="brand_theme_dynasty_revival_accessibility">다이너스티 리바이벌 테마, 깊은 툼 메탈 블랙과 밝은 리액터 그린.</string>
    <string name="brand_theme_sepulcher_cyan_title">세펄커 시안</string>
    <string name="brand_theme_sepulcher_cyan_description">정적인 왕실 기계의 광채를 위한 차가운 세펄커 스틸과 절제된 시안 그린.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">세펄커 시안 테마, 차갑고 어두운 스틸과 차분한 시안 그린.</string>
    <string name="brand_theme_tomb_sigil_title">툼 시질</string>
    <string name="brand_theme_tomb_sigil_description">의식적인 왕조의 문장을 위한 따뜻한 지하실 철색과 선명한 리바이벌 그린.</string>
    <string name="brand_theme_tomb_sigil_accessibility">툼 시질 테마, 어두운 지하실 철색과 선명한 리바이벌 그린.</string>
    <string name="brand_theme_ancient_alloy_title">고대 합금</string>
    <string name="brand_theme_ancient_alloy_description">툼 포지의 광채를 위한 풍화된 금속 그림자와 차가운 터콰이즈.</string>
    <string name="brand_theme_ancient_alloy_accessibility">고대 합금 테마, 어두운 브론즈 그레이와 밝은 터콰이즈.</string>
    <string name="brand_theme_immortal_rot_title">불멸의 부패</string>
    <string name="brand_theme_immortal_rot_description">고사리 그린과 시트린 옐로우가 습하고 무성한 듀얼 톤 팔레트를 형성합니다.</string>
    <string name="brand_theme_immortal_rot_accessibility">불멸의 부패 테마, 고사리 그린과 시트린 옐로우.</string>
    <string name="brand_theme_scarlet_carnage_title">진홍빛 살육</string>
    <string name="brand_theme_scarlet_carnage_description">짙은 빨간색과 황동색이 피와 전쟁의 금속이라는 잔혹한 듀얼 톤 팔레트를 벼려냅니다.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">진홍빛 살육 테마, 짙은 빨간색과 어두운 골든로드 황동색.</string>
    <string name="brand_theme_exquisite_fall_title">정교한 몰락</string>
    <string name="brand_theme_exquisite_fall_description">깊고 어두운 보라색과 스크리머 핑크가 허영과 감각의 퇴폐적인 듀얼 톤 팔레트를 생성합니다.</string>
    <string name="brand_theme_exquisite_fall_accessibility">정교한 몰락 테마, 깊고 어두운 보라색과 스크리머 핑크 및 금색 테두리.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">변이의 미궁</string>
    <string name="brand_theme_labyrinth_of_mutability_description">채도가 낮은 시안 블루와 밝은 형광 보라색이 금색 테두리와 함께 변화하는 듀얼 톤 미궁을 형성합니다.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">변이의 미궁 테마, 채도 낮은 시안 블루와 밝은 형광 보라색 및 금색 테두리.</string>
