    <string name="brand_theme_mars_relic_title">Реліквія Марса</string>
    <string name="brand_theme_mars_relic_description">Глибокий червоний із пергаментом для церемоніального архівного вигляду.</string>
    <string name="brand_theme_mars_relic_accessibility">Тема Реліквія Марса, глибокий червоний із пергаментно-бежевим.</string>
    <string name="brand_theme_black_crimson_rite_title">Чорно-багряний ритуал</string>
    <string name="brand_theme_black_crimson_rite_description">Сажистий чорний і ритуальний багряний для суворого настрою машинного святилища.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Тема Чорно-багряний ритуал, майже чорний із яскравим багряно-червоним.</string>
    <string name="brand_theme_scarlet_guard_title">Багряна варта</string>
    <string name="brand_theme_scarlet_guard_description">Білий слонової кістки та запечатаний багряний для стриманого геральдичного тону.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Тема Багряна варта, світла слонова кістка з темно-багряно-червоним.</string>
    <string name="brand_theme_dynasty_revival_title">Відродження династії</string>
    <string name="brand_theme_dynasty_revival_description">Чорний метал гробниці та класичний реакторний зелений для ядра пробудженої династії.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Тема Відродження династії, глибокий чорний метал гробниці з яскравим реакторним зеленим.</string>
    <string name="brand_theme_sepulcher_cyan_title">Склеповий ціан</string>
    <string name="brand_theme_sepulcher_cyan_description">Холодна сталь склепу й стриманий ціан-зелений для тихішого королівського машинного сяйва.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Тема Склеповий ціан, холодна темна сталь із приглушеним ціан-зеленим.</string>
    <string name="brand_theme_tomb_sigil_title">Сигіл гробниці</string>
    <string name="brand_theme_tomb_sigil_description">Тепле криптове залізо й яскравий зелений відродження для церемоніального знака династії.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Тема Сигіл гробниці, темне криптове залізо з яскравим зеленим відродження.</string>
    <string name="brand_theme_ancient_alloy_title">Давній сплав</string>
    <string name="brand_theme_ancient_alloy_description">Тіні зношеного металу та холодна бірюза для сяйва гробничної кузні.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Тема Давній сплав, темний бронзово-сірий із яскравою бірюзою.</string>
    <string name="brand_theme_immortal_rot_title">The Immortal Rot</string>
    <string name="brand_theme_immortal_rot_description">Папоротево-зелений і цитриново-жовтий створюють вологу, зарослу палітру dual-tone.</string>
    <string name="brand_theme_immortal_rot_accessibility">Тема The Immortal Rot, папоротево-зелений із цитриново-жовтим.</string>
    <string name="brand_theme_scarlet_carnage_title">The Scarlet Carnage</string>
    <string name="brand_theme_scarlet_carnage_description">Темно-червоний і латунь творять жорстоку палітру dual-tone крові й бойового металу.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Тема The Scarlet Carnage, темно-червоний із темною золотистою латунню.</string>
    <string name="brand_theme_exquisite_fall_title">Exquisite Fall</string>
    <string name="brand_theme_exquisite_fall_description">Глибокий темний фіолетовий і screamer pink створюють декадентську палітру dual-tone марнославства й відчуття.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Тема Exquisite Fall, глибокий темний фіолетовий зі screamer pink і золотим контуром.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">The Labyrinth of Mutability</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Малонасичений ціан-синій і яскравий флуоресцентний фіолетовий утворюють мінливий dual-tone лабіринт із золотою крайкою.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Тема The Labyrinth of Mutability, малонасичений ціан-синій із яскравим флуоресцентним фіолетовим і золотим контуром.</string>
